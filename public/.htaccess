# Retirely — Apache config for Hostinger

# Routing: pre-rendered SEO landing pages (clean URLs) + SPA fallback for the app.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Never rewrite the SPA entry point itself.
  RewriteRule ^index\.html$ - [L]

  # Don't add a trailing-slash redirect for directories — keeps canonical URLs
  # stable (we serve flat .html files, not directory indexes).
  DirectorySlash Off

  # 1) Serve pre-rendered SEO pages at their clean, extensionless URL with NO
  #    redirect:  /rrsp-calculator → rrsp-calculator.html (only if that file
  #    exists). This must run BEFORE the SPA fallback below.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ /$1.html [L]

  # 2) SPA fallback: anything else that isn't a real file/dir (e.g. /speculator,
  #    /estate, and client-side routes) serves the app shell.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

# Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Enforce HTTPS for a year, including subdomains. "always" so it's sent on
  # redirects/error responses too. The whole site is HTTPS-only on Hostinger.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # This is a static calculator — it needs none of these powerful features.
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
